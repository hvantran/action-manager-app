# Production configuration - Route through API Gateway with Keycloak authentication
# All API calls go through the Gateway which handles OAuth2/OIDC authentication
# Related to hvantran/project-management#187

# Gateway URL (update based on your production domain)
REACT_APP_ACTION_MANAGER_BACKEND_URL=http://api-gateway:8081/api/action-manager
REACT_APP_TEMPLATE_MANAGER_BACKEND_URL=http://api-gateway:8081/api/template-manager
REACT_APP_ECOMMERCE_MANAGER_BACKEND_URL=http://api-gateway:8081/api/e-commerce-stats
REACT_APP_ENDPOINT_MANAGER_BACKEND_URL=http://api-gateway:8081/api/ext-endpoint-collector
REACT_APP_KAFKA_NOTIFIER_URL=http://api-gateway:8081/api/kafka-notifier

# Frontend URLs (keep as-is)
REACT_APP_TEMPLATE_MANAGER_FRONTEND_URL=http://templatemanui.local:6088
REACT_APP_ACTION_MANAGER_FRONTEND_URL=http://actmanagerui.local:6084
REACT_APP_ECOMMERCE_MANAGER_FRONTEND_URL=http://ecommerceui.local:8080
REACT_APP_ENDPOINT_MANAGER_FRONTEND_URL=http://extendpointui.local:6086

# Service names
REACT_APP_TEMPLATE_MANAGER_NAME=Template Manager
REACT_APP_ACTION_MANAGER_NAME=Action Manager
REACT_APP_ECOMMERCE_MANAGER_NAME=Ecommerce Manager
REACT_APP_ENDPOINT_MANAGER_NAME=Data Collector

# Application configuration
REACT_APP_TROUBLESHOOTING_BASE_URL=http://kibana.local.vn:5601/
REACT_APP_PAGES=[{"name":"actions","link":"/actions","uiName":"Actions"},{"name":"jobs","link":"/jobs","uiName":"Jobs"}]
REACT_APP_NAME=Action Manager
REACT_APP_ICON=action-manager.png
