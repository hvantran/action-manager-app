# Route all API calls through the Gateway for OAuth2 authentication
# Gateway URL structure: http://<gateway-host>:<gateway-port>/api/<service-name>
# The Gateway handles authentication, JWT validation, and token relay to backend services
# Related to hvantran/project-management#187
REACT_APP_ACTION_MANAGER_BACKEND_URL=http://localhost:6081/api/action-manager
REACT_APP_TEMPLATE_MANAGER_BACKEND_URL=http://localhost:6081/api/template-manager
REACT_APP_ECOMMERCE_MANAGER_BACKEND_URL=http://localhost:6081/api/e-commerce-stats
REACT_APP_ENDPOINT_MANAGER_BACKEND_URL=http://localhost:6081/api/ext-endpoint-collector
REACT_APP_KAFKA_NOTIFIER_URL=http://localhost:6081/api/kafka-notifier
REACT_APP_TEMPLATE_MANAGER_FRONTEND_URL=http://templatemanui.local:6088
REACT_APP_ACTION_MANAGER_FRONTEND_URL=http://actmanagerui.local:6084
REACT_APP_ECOMMERCE_MANAGER_FRONTEND_URL=http://ecommerceui.local:8080
REACT_APP_ENDPOINT_MANAGER_FRONTEND_URL=http://extendpointui.local:6086
REACT_APP_TEMPLATE_MANAGER_NAME=Template Manager
REACT_APP_ACTION_MANAGER_NAME=Action Manager
REACT_APP_ECOMMERCE_MANAGER_NAME=Ecommerce Manager
REACT_APP_ENDPOINT_MANAGER_NAME=Data Collector
